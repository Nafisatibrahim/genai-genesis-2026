# Ignore everything at repo root except whitelisted paths
*
!.gitignore
!/README.md
!/Procfile
!/requirements.txt
!/phases.txt
!/overview.md
!/plan.md
!/LICENSE
!/quick_test.py
!/docs/
!/docs/**
!/frontend/
!/frontend/**
!/backend/
!/backend/**
!/backend_test/
!/backend_test/**
!/frontendapp/
!/frontendapp/**
frontendapp/node_modules/
frontendapp/dist/

# Environment and secrets (API keys) — ignored everywhere
.env

# Cursor IDE
.cursor